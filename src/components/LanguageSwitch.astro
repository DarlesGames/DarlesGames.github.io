---
interface Props {
  lang: 'ru' | 'en';
  ruPath: string;
  enPath: string;
}

const { lang, ruPath, enPath } = Astro.props;
---

<nav class="language-switch" aria-label="Language / Язык">
  <a href={ruPath} lang="ru" hreflang="ru" class:list={{ 'is-active': lang === 'ru' }} aria-current={lang === 'ru' ? 'page' : undefined}>RU</a>
  <span aria-hidden="true">/</span>
  <a href={enPath} lang="en" hreflang="en" class:list={{ 'is-active': lang === 'en' }} aria-current={lang === 'en' ? 'page' : undefined}>EN</a>
</nav>
