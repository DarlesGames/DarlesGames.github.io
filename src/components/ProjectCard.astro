---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  lang: 'ru' | 'en';
  detailsLabel: string;
  compact?: boolean;
}

const { project, lang, detailsLabel, compact = false } = Astro.props;
const data = project.data;
const root = lang === 'ru' ? '/projects/' : '/en/projects/';
const searchText = [
  data.title[lang],
  data.type[lang],
  data.short[lang],
  data.details[lang],
  data.statusLabel[lang],
  data.category,
  ...data.stack,
  ...data.solutions[lang],
].join(' ').toLocaleLowerCase(lang === 'ru' ? 'ru-RU' : 'en-US');
---

<article
  class:list={['project-card', `accent-${data.accent}`, { 'project-card-compact': compact }]}
  data-category={data.category}
  data-search={searchText}
>
  <a class="project-cover" href={`${root}${project.id}/`} aria-label={`${detailsLabel}: ${data.title[lang]}`}>
    {data.cover ? (
      <img src={data.cover} alt="" width="720" height="405" loading="lazy" decoding="async" />
    ) : (
      <span class="cover-placeholder" aria-hidden="true"><i>✦</i><b>Darles Games</b></span>
    )}
    <span class="status-badge project-status">{data.statusLabel[lang]}</span>
  </a>
  <div class="project-card-body">
    <p class="project-type">{data.type[lang]}</p>
    <h2><a href={`${root}${project.id}/`}>{data.title[lang]}</a></h2>
    <p>{data.short[lang]}</p>
    <div class="tag-list">
      {data.stack.slice(0, compact ? 3 : 4).map((tag) => <span>{tag}</span>)}
    </div>
    <a class="text-link" href={`${root}${project.id}/`}>{detailsLabel} <span aria-hidden="true">→</span></a>
  </div>
</article>
